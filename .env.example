# Copy this file to .env.local and fill in the values.
# Never commit .env.local to source control.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email (Nodemailer / Gmail) ────────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
ADMIN_EMAIL=

# ── Jitsi Video ───────────────────────────────────────────────────────────────
JITSI_APP_ID=
JITSI_JWT_KID=
# PEM-encoded RSA private key (RS256). Server-side only — never use NEXT_PUBLIC_.
JITSI_PRIVATE_KEY=

# ── Action Network ────────────────────────────────────────────────────────────
# Server-side only — never expose as NEXT_PUBLIC_.
ACTION_NETWORK_API_KEY=

# ── Google Forms ──────────────────────────────────────────────────────────────
# Server-side only — never expose as NEXT_PUBLIC_.
GOOGLE_FORM_SHARE_YOUR_STORY_URL=

