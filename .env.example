# Copy this file to .env.local and fill in the values.
# Never commit .env.local to source control.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email (Nodemailer / Gmail) ────────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
ADMIN_EMAIL=

# ── Jitsi Video ───────────────────────────────────────────────────────────────
JITSI_APP_ID=
JITSI_JWT_KID=
# PEM-encoded RSA private key (RS256). Server-side only — never use NEXT_PUBLIC_.
JITSI_PRIVATE_KEY=

# ── Action Network ────────────────────────────────────────────────────────────
# Server-side only — never expose as NEXT_PUBLIC_.
ACTION_NETWORK_API_KEY=

# ── Google Forms ──────────────────────────────────────────────────────────────
# Server-side only — never expose as NEXT_PUBLIC_.
GOOGLE_FORM_SHARE_YOUR_STORY_URL=

# ── Survey ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SURVEY_COMPANY_NAME=

# Encryption
SURVEY_ENCRYPTION_KEY=       # openssl rand -hex 32
SURVEY_DOMAIN_SALT=          # openssl rand -hex 16

#Cloudflare Turnstile
TURNSTILE_SECRET_KEY=        # server-side
NEXT_PUBLIC_TURNSTILE_SITE_KEY=  # client-side

# To use TURNSTILE test keys locally, uncomment these 3 key/value pairs
# TURNSTILE_SKIP_ACTION_CHECK=1
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA