# Setup instructions: see e2e/README.md
# Playwright E2E test credentials
# Copy to .env.e2e and fill in values. Never commit .env.e2e.

# Approved + onboarded user
PW_E2E_APPROVED_ONBOARDED_EMAIL=
PW_E2E_APPROVED_ONBOARDED_PASSWORD=

# Unapproved + onboarded user
PW_E2E_UNAPPROVED_ONBOARDED_EMAIL=
PW_E2E_UNAPPROVED_ONBOARDED_PASSWORD=

# Unonboarded user
PW_E2E_UNONBOARDED_EMAIL=
PW_E2E_UNONBOARDED_PASSWORD=